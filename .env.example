# StudyMate AI Environment Variables
# Copy this file to a new file named '.env' and fill in your Gemini API Key.

# Google Gemini API Key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Google Gemini model name (defaults to gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash
